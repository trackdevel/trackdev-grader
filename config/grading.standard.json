{
  "$schema": "./grading.schema.json",
  "version": "2.0.0",
  "title": "Grading v2 — cohort-relative quality / complexity / size + contribution-based students",
  "notes": [
    "Grading v2 (see plans/total_grading/GRADING_V2.md): project_final = present-renormalized blend of quality (50%), complexity (30%), size (20%).",
    "Quality / complexity / size axis scores are hybrid cohort-normalized in grade_core::grade_cohort and injected as quality, complexity, size (+ *_present flags) before project formulas run.",
    "Story points and ai_factor never enter project_final. AI keep affects only student_eff → student_contribution.",
    "student_base = project_final × student_contribution × team_size (enrolled roster). student_penalty is behavioural CRITICAL flags only.",
    "Formulas are grade_core::Expr AST; infix is human review only.",
    "Div semantics: 0/0 → 0. Rounding on meta.final_outputs only."
  ],
  "meta": {
    "decimals": 2,
    "quantize_final": 0.0,
    "penalty_mode": "subtractive",
    "final_outputs": ["project_final", "student_final"]
  },
  "weights": {
    "w_quality": 0.5,
    "w_complexity": 0.3,
    "w_size": 0.2,
    "w_android": 0.6,
    "w_spring": 0.4,
    "w_mi": 0.35,
    "w_arch": 0.3,
    "w_density": 0.25,
    "w_mutation": 0.1,
    "ai_strength": 1.0,
    "floor_keep": 0.2,
    "undeclared_model_m": 1.0,
    "undeclared_level_l": 0.5,
    "student_penalty_cap": 1.0,
    "crit_flag_points": 0.75,
    "mi_floor": 50.0,
    "mi_ceiling": 85.0,
    "arch_norm": 4.0,
    "density_ceiling": 5.0,
    "inventory_count_ceiling": 50.0,
    "inventory_depth_ceiling": 30.0,
    "inventory_density_ceiling": 10.0,
    "prod_loc_ceiling": 50000.0
  },
  "anchors": {
    "code_quality_raw": { "floor": 50.0, "ceiling": 85.0 },
    "mutation_score": { "floor": 0.0, "ceiling": 1.0 },
    "arch_weighted": { "floor": 0.0, "ceiling": 8.0 },
    "violation_density": { "floor": 0.0, "ceiling": 5.0 }
  },
  "models": {
    "Cap": 0.0,
    "Copilot-Auto": 0.7,
    "Cursor": 0.9,
    "Kimi-2.6": 0.85,
    "DeepSeek-v4": 0.85,
    "Sonnet-4.6": 0.9,
    "Gemini-3.1": 1.0,
    "Opus-4.6-4.7": 1.0,
    "GPT-5.5": 1.0,
    "GPT-5.4": 1.0,
    "GPT-5.3-codex": 1.0,
    "GPT-5.2-codex": 1.0
  },
  "levels": {
    "A": 0.0,
    "B": 0.25,
    "C": 0.5,
    "D": 0.75,
    "E": 1.0
  },
  "manual_fields": {
    "defs": [],
    "values": {}
  },
  "inputs": {
    "raw": [
      "code_quality_raw",
      "mutation_score",
      "arch_crit_count",
      "arch_warn_count",
      "team_size",
      "cq_present",
      "arch_present",
      "quality",
      "complexity",
      "size",
      "quality_present",
      "complexity_present",
      "size_present"
    ],
    "task": ["raw_points", "model_m", "level_l", "declared"],
    "structural": [
      "sum_raw",
      "sum_eff",
      "student_eff",
      "contribution",
      "student_contribution",
      "student_critical_count",
      "penalty_on"
    ]
  },
  "formulas": {
    "task": [
      {
        "name": "keep",
        "infix": "1 - (1 - floor_keep) * ai_strength * model_m * level_l",
        "expr": {
          "op": "sub",
          "lhs": { "op": "num", "value": 1 },
          "rhs": {
            "op": "mul",
            "factors": [
              { "op": "sub", "lhs": { "op": "num", "value": 1 }, "rhs": { "op": "var", "name": "floor_keep" } },
              { "op": "var", "name": "ai_strength" },
              { "op": "var", "name": "model_m" },
              { "op": "var", "name": "level_l" }
            ]
          }
        }
      }
    ],
    "project": [
      {
        "name": "project_final",
        "infix": "(w_quality*quality*quality_present + w_complexity*complexity*complexity_present + w_size*size*size_present) / (w_quality*quality_present + w_complexity*complexity_present + w_size*size_present)",
        "expr": {
          "op": "div",
          "num": {
            "op": "add",
            "terms": [
              {
                "op": "mul",
                "factors": [
                  { "op": "var", "name": "w_quality" },
                  { "op": "var", "name": "quality" },
                  { "op": "var", "name": "quality_present" }
                ]
              },
              {
                "op": "mul",
                "factors": [
                  { "op": "var", "name": "w_complexity" },
                  { "op": "var", "name": "complexity" },
                  { "op": "var", "name": "complexity_present" }
                ]
              },
              {
                "op": "mul",
                "factors": [
                  { "op": "var", "name": "w_size" },
                  { "op": "var", "name": "size" },
                  { "op": "var", "name": "size_present" }
                ]
              }
            ]
          },
          "den": {
            "op": "add",
            "terms": [
              {
                "op": "mul",
                "factors": [
                  { "op": "var", "name": "w_quality" },
                  { "op": "var", "name": "quality_present" }
                ]
              },
              {
                "op": "mul",
                "factors": [
                  { "op": "var", "name": "w_complexity" },
                  { "op": "var", "name": "complexity_present" }
                ]
              },
              {
                "op": "mul",
                "factors": [
                  { "op": "var", "name": "w_size" },
                  { "op": "var", "name": "size_present" }
                ]
              }
            ]
          }
        }
      }
    ],
    "student": [
      {
        "name": "student_penalty",
        "infix": "penalty_on * min(student_penalty_cap, crit_flag_points*student_critical_count)",
        "expr": {
          "op": "mul",
          "factors": [
            { "op": "var", "name": "penalty_on" },
            {
              "op": "min",
              "args": [
                { "op": "var", "name": "student_penalty_cap" },
                {
                  "op": "mul",
                  "factors": [
                    { "op": "var", "name": "crit_flag_points" },
                    { "op": "var", "name": "student_critical_count" }
                  ]
                }
              ]
            }
          ]
        }
      },
      {
        "name": "student_base",
        "infix": "project_final * student_contribution * team_size",
        "expr": {
          "op": "mul",
          "factors": [
            { "op": "var", "name": "project_final" },
            { "op": "var", "name": "student_contribution" },
            { "op": "var", "name": "team_size" }
          ]
        }
      },
      {
        "name": "student_final",
        "infix": "clamp(student_base - student_penalty, 0, 10)",
        "expr": {
          "op": "clamp",
          "x": {
            "op": "sub",
            "lhs": { "op": "var", "name": "student_base" },
            "rhs": { "op": "var", "name": "student_penalty" }
          },
          "lo": { "op": "num", "value": 0 },
          "hi": { "op": "num", "value": 10 }
        }
      }
    ]
  }
}
