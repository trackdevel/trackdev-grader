{
  "$schema": "./grading.schema.json",
  "anchors": {
    "activity_count": {
      "ceiling": 11.0,
      "floor": 0.0
    },
    "arch_weighted": {
      "ceiling": 7.15,
      "floor": 0.0
    },
    "avg_cc_per_controller": {
      "ceiling": 1.64,
      "floor": 0.0
    },
    "avg_cc_per_fragment": {
      "ceiling": 4.0,
      "floor": 0.0
    },
    "avg_statements_per_endpoint": {
      "ceiling": 3.94,
      "floor": 0.0
    },
    "code_quality_raw": {
      "ceiling": 98.0,
      "floor": 85.0
    },
    "controller_count": {
      "ceiling": 22.0,
      "floor": 0.0
    },
    "custom_query_count": {
      "ceiling": 58.3,
      "floor": 0.0
    },
    "endpoint_count": {
      "ceiling": 159.5,
      "floor": 0.0
    },
    "entity_count": {
      "ceiling": 30.7,
      "floor": 0.0
    },
    "fragment_count": {
      "ceiling": 46.2,
      "floor": 0.0
    },
    "mutation_score": {
      "ceiling": 1.0,
      "floor": 0.0
    },
    "nav_dispatch_count": {
      "ceiling": 70.4,
      "floor": 0.0
    },
    "nav_dispatch_density": {
      "ceiling": 1.89,
      "floor": 0.0
    },
    "observe_call_count": {
      "ceiling": 166.1,
      "floor": 0.0
    },
    "production_loc": {
      "ceiling": 22214.1,
      "floor": 0.0
    },
    "production_statement_count": {
      "ceiling": 12523.1,
      "floor": 0.0
    },
    "reactive_state_field_count": {
      "ceiling": 119.9,
      "floor": 0.0
    },
    "reactive_wiring_density": {
      "ceiling": 4.15,
      "floor": 0.0
    },
    "repository_count": {
      "ceiling": 11.0,
      "floor": 0.0
    },
    "room_database_count": {
      "ceiling": 1.1,
      "floor": 0.0
    },
    "scheduled_task_count": {
      "ceiling": 4.4,
      "floor": 0.0
    },
    "service_count": {
      "ceiling": 25.3,
      "floor": 0.0
    },
    "viewmodel_count": {
      "ceiling": 50.6,
      "floor": 0.0
    },
    "violation_density": {
      "ceiling": 1.0,
      "floor": 0.0
    }
  },
  "constants": [],
  "formulas": {
    "project": [
      {
        "expr": {
          "op": "add",
          "terms": [
            {
              "name": "quality_floor",
              "op": "var"
            },
            {
              "factors": [
                {
                  "name": "quality_blend",
                  "op": "var"
                },
                {
                  "den": {
                    "op": "num",
                    "value": 10
                  },
                  "num": {
                    "name": "quality_eff",
                    "op": "var"
                  },
                  "op": "div"
                }
              ],
              "op": "mul"
            }
          ]
        },
        "infix": "quality_floor + quality_blend * quality_eff / 10",
        "name": "quality_multiplier"
      },
      {
        "expr": {
          "op": "max",
          "args": [
            {
              "op": "sub",
              "lhs": {
                "factors": [
                  {
                    "name": "work_base",
                    "op": "var"
                  },
                  {
                    "name": "quality_multiplier",
                    "op": "var"
                  },
                  {
                    "name": "ai_factor",
                    "op": "var"
                  }
                ],
                "op": "mul"
              },
              "rhs": {
                "name": "team_quality_penalty",
                "op": "var"
              }
            },
            {
              "op": "num",
              "value": 0
            }
          ]
        },
        "infix": "max(work_base * quality_multiplier * ai_factor - team_quality_penalty, 0)",
        "name": "project_raw"
      },
      {
        "expr": {
          "op": "min",
          "args": [
            {
              "op": "num",
              "value": 10
            },
            {
              "op": "mul",
              "factors": [
                {
                  "op": "num",
                  "value": 10
                },
                {
                  "op": "pow",
                  "base": {
                    "op": "div",
                    "num": {
                      "name": "project_raw",
                      "op": "var"
                    },
                    "den": {
                      "op": "num",
                      "value": 10
                    }
                  },
                  "exp": {
                    "name": "project_grade_gamma",
                    "op": "var"
                  }
                }
              ]
            }
          ]
        },
        "infix": "min(10, 10 * pow(project_raw / 10, project_grade_gamma))",
        "name": "project_final"
      }
    ],
    "student": [
      {
        "expr": {
          "factors": [
            {
              "name": "penalty_on",
              "op": "var"
            },
            {
              "args": [
                {
                  "name": "student_penalty_cap",
                  "op": "var"
                },
                {
                  "factors": [
                    {
                      "name": "crit_flag_points",
                      "op": "var"
                    },
                    {
                      "name": "student_critical_count",
                      "op": "var"
                    }
                  ],
                  "op": "mul"
                }
              ],
              "op": "min"
            }
          ],
          "op": "mul"
        },
        "infix": "penalty_on * min(student_penalty_cap, crit_flag_points*student_critical_count)",
        "name": "student_penalty"
      },
      {
        "expr": {
          "factors": [
            {
              "name": "project_final",
              "op": "var"
            },
            {
              "name": "student_contribution",
              "op": "var"
            },
            {
              "name": "team_size",
              "op": "var"
            }
          ],
          "op": "mul"
        },
        "infix": "project_final * student_contribution * team_size",
        "name": "student_base"
      },
      {
        "expr": {
          "lhs": {
            "lhs": {
              "name": "student_base",
              "op": "var"
            },
            "op": "sub",
            "rhs": {
              "name": "student_penalty",
              "op": "var"
            }
          },
          "op": "sub",
          "rhs": {
            "name": "codequality_penalty",
            "op": "var"
          }
        },
        "infix": "student_base - student_penalty - codequality_penalty",
        "name": "student_net"
      },
      {
        "expr": {
          "name": "student_net",
          "op": "var"
        },
        "infix": "student_net",
        "name": "student_curved"
      },
      {
        "expr": {
          "hi": {
            "op": "num",
            "value": 10
          },
          "lo": {
            "op": "num",
            "value": 0
          },
          "op": "clamp",
          "x": {
            "op": "add",
            "terms": [
              {
                "name": "student_curved",
                "op": "var"
              },
              {
                "op": "div",
                "num": {
                  "op": "mul",
                  "factors": [
                    {
                      "name": "student_lift_k",
                      "op": "var"
                    },
                    {
                      "name": "student_curved",
                      "op": "var"
                    },
                    {
                      "op": "max",
                      "args": [
                        {
                          "op": "num",
                          "value": 0
                        },
                        {
                          "op": "sub",
                          "lhs": {
                            "name": "student_lift_pivot",
                            "op": "var"
                          },
                          "rhs": {
                            "name": "student_curved",
                            "op": "var"
                          }
                        }
                      ]
                    }
                  ]
                },
                "den": {
                  "name": "student_lift_pivot",
                  "op": "var"
                }
              }
            ]
          }
        },
        "infix": "clamp(student_curved + student_lift_k * student_curved * max(0, student_lift_pivot - student_curved) / student_lift_pivot, 0, 10)",
        "name": "student_final"
      }
    ],
    "task": [
      {
        "expr": {
          "op": "add",
          "terms": [
            {
              "factors": [
                {
                  "name": "declared",
                  "op": "var"
                },
                {
                  "lhs": {
                    "op": "num",
                    "value": 1
                  },
                  "op": "sub",
                  "rhs": {
                    "factors": [
                      {
                        "lhs": {
                          "op": "num",
                          "value": 1
                        },
                        "op": "sub",
                        "rhs": {
                          "name": "floor_keep",
                          "op": "var"
                        }
                      },
                      {
                        "name": "ai_strength",
                        "op": "var"
                      },
                      {
                        "name": "model_m",
                        "op": "var"
                      },
                      {
                        "name": "level_l",
                        "op": "var"
                      }
                    ],
                    "op": "mul"
                  }
                }
              ],
              "op": "mul"
            },
            {
              "factors": [
                {
                  "lhs": {
                    "op": "num",
                    "value": 1
                  },
                  "op": "sub",
                  "rhs": {
                    "name": "declared",
                    "op": "var"
                  }
                },
                {
                  "name": "undeclared_keep",
                  "op": "var"
                }
              ],
              "op": "mul"
            }
          ]
        },
        "infix": "declared * (1 - (1 - floor_keep) * ai_strength * model_m * level_l) + (1 - declared) * undeclared_keep",
        "name": "keep"
      }
    ]
  },
  "inputs": {
    "raw": [
      "code_quality_raw",
      "mutation_score",
      "arch_crit_count",
      "arch_warn_count",
      "team_size",
      "cq_present",
      "arch_present",
      "quality",
      "complexity",
      "size",
      "work_base",
      "quality_eff",
      "quality_multiplier",
      "quality_present",
      "complexity_present",
      "size_present",
      "work_base_present"
    ],
    "structural": [
      "sum_raw",
      "sum_eff",
      "student_eff",
      "contribution",
      "student_contribution",
      "student_critical_count",
      "codequality_penalty",
      "penalty_on"
    ],
    "task": [
      "raw_points",
      "model_m",
      "level_l",
      "declared"
    ]
  },
  "levels": {
    "A": 0.0,
    "B": 0.25,
    "C": 0.5,
    "D": 0.75,
    "E": 1.0
  },
  "manual_fields": {
    "defs": [],
    "values": {}
  },
  "meta": {
    "decimals": 2,
    "final_outputs": [
      "project_final",
      "student_final"
    ],
    "penalty_mode": "subtractive",
    "quantize_final": 0.0
  },
  "models": {
    "Cap": 0.0,
    "Copilot-Auto": 0.7,
    "Cursor": 0.9,
    "DeepSeek-v4": 0.85,
    "GPT-5.2-codex": 1.0,
    "GPT-5.3-codex": 1.0,
    "GPT-5.4": 1.0,
    "GPT-5.5": 1.0,
    "Gemini-3.1": 1.0,
    "Kimi-2.6": 0.85,
    "Opus-4.6-4.7": 1.0,
    "Sonnet-4.6": 0.9
  },
  "notes": [
    "Grading v5: project_final = min(10, 10·(project_raw/10)^project_grade_gamma), clamped to a 10 ceiling. project_raw = max(work_base × quality_multiplier × ai_factor − team_quality_penalty, 0). work_base = (present-renorm blend of size and complexity, scaled by work_scale) + extra_tech. project_grade_gamma=2.4921 anchors pds26-3b Sergi Fosas at 5.0. Student curve is transparent in v5: student_curved = student_net (the anchor/gamma tent was removed).",
    "extra_tech is computed in grade_core from baseline-subtracted inventory depth detectors (FCM, MinIO, OkHttp APIs, …) and merged into work_base before project formulas run; work_base_present is true when either structural axes or extra_tech contribute.",
    "quality_eff = absolute-mapped maintainability (code_quality_raw on mi_floor→0 .. mi_ceiling→10, NO cohort-percentile stretch) plus mutation when present, MINUS a subtractive layer-architecture penalty min(arch_cap, arch_k × (arch_crit×2 + arch_warn×0.5)). arch_* counts are layer_dependency only; specific per-file violations are charged to students, not the project.",
    "Size / complexity / quality axis scores are computed in grade_core::grade_cohort; structural work_base, quality_eff, and quality_multiplier are injected before project formulas run, then extra_tech is merged into work_base (structural×work_scale + extra_tech).",
    "ai_factor (= team sum_eff/sum_raw) multiplies project_final, so team AI usage lowers the whole project grade; combined with student_contribution=student_eff/sum_eff, each student's base resolves to quality × team_size × student_eff/sum_raw.",
    "student_base = project_final × student_contribution × team_size (enrolled roster). student_net = student_base − student_penalty − codequality_penalty. v5 transparent curve: student_curved = student_net (no anchor/gamma); student_final applies student_lift_* and clamps [0,10]. An equal contributor on project P scores P for P≥student_lift_pivot; below-equal shares and penalties scale down. Pareto-up vs the old anchor curve.",
    "codequality_penalty: cohort-wide percentile bands per signal (architecture / cyclomatic-complexity / static-analysis), ranked by weighted blame ÷ max(student_eff, cq_min_points). Top cq_crit_pct → cq_crit_pts, next band up to cq_warn_pct → cq_warn_pts, gated by cq_abs_floor, summed across signals and capped at cq_cap. Computed in grade_core::grade_cohort and injected as a per-student variable.",
    "Formulas are grade_core::Expr AST; infix is human review only.",
    "Div semantics: 0/0 → 0. Rounding on meta.final_outputs only.",
    "Anchors auto-calibrated (14 projects), then work_scale MANUALLY overridden 1.2728→1.4925 so pds26-1b's pre-AI project grade reaches 10 (linear lift of all projects; project_final clamped at 10). arch_k=0.8392. MI/arch/inventory floor & ceiling from cohort min/max. NOTE: do not re-run calibrate-anchors or it resets work_scale to the cohort-top work_base target."
  ],
  "title": "Grading v5 — transparent student curve, work-scaled project grade, author-charged code-quality penalties",
  "version": "5.0.0",
  "weights": {
    "ai_strength": 1.0,
    "arch_cap": 3.0,
    "arch_k": 0.8392,
    "arch_norm": 3.575,
    "cq_abs_floor": 0.0,
    "cq_cap": 1.0,
    "cq_crit_pct": 0.1,
    "cq_crit_pts": 0.5,
    "cq_min_points": 1.0,
    "cq_warn_pct": 0.3,
    "cq_warn_pts": 0.25,
    "qpen_arch_scale": 0.1,
    "qpen_author_cap": 2.0,
    "qpen_author_share": 0.8,
    "qpen_cx_scale": 0.02,
    "qpen_sa_scale": 0.1,
    "qpen_sig_cap": 1.0,
    "project_grade_gamma": 2.4921,
    "student_lift_k": 0.64,
    "student_lift_pivot": 7.0,
    "qpen_team_cap": 1.5,
    "qpen_team_share": 0.2,
    "crit_flag_points": 0.75,
    "density_ceiling": 1.0,
    "floor_keep": 0.2,
    "inventory_count_ceiling": 50.0,
    "inventory_density_ceiling": 10.0,
    "inventory_depth_ceiling": 30.0,
    "mi_ceiling": 98.0,
    "mi_floor": 85.0,
    "prod_loc_ceiling": 22214.1,
    "prod_stmt_ceiling": 12000.0,
    "quality_blend": 0.5,
    "quality_floor": 0.5,
    "student_penalty_cap": 1.0,
    "undeclared_keep": 0.5,
    "undeclared_level_l": 0.5,
    "undeclared_model_m": 0.0,
    "w_android": 0.6,
    "w_arch": 0.3,
    "w_complexity": 0.3,
    "w_mi": 0.35,
    "w_mutation": 0.1,
    "w_quality": 0.5,
    "w_size": 0.2,
    "w_spring": 0.4,
    "work_scale": 1.4925
  }
}
